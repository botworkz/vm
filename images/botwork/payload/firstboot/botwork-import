#!/bin/sh
# botwork-import — boot-time DB seed via admin-api (RFE #106 PR4).
#
# Called by botwork-import.service after admin-api is up.
#
# Resolves admin-api's bridge IP through `docker inspect` (the
# `admin_api` DNS alias is only resolvable inside botwork-internal,
# not from the host netns), polls /admin/api/v1/health until it
# answers, then runs `botwork-tools bootstrap` against the same IP.
#
# Why a script-on-disk vs. an inline `ExecStart=/usr/bin/sh -c '…'`:
# systemd parses `${foo}` in unit-file Exec* lines as its OWN
# environment-variable substitution BEFORE handing the string to
# the shell — so `${ip}` and `${i}` would never reach `sh` for
# assignment. Putting the script on disk dodges that entire
# substitution layer; systemd just execs the file.
#
# Exit codes match `botwork-tools bootstrap`'s 1:1 (see botwork's
# tools/src/bootstrap/mod.rs); we add exit 8 for "admin-api never
# answered /health" which is distinct from "admin-api answered but
# rejected the apply" (exit 6) and "admin-api transport / 5xx
# mid-apply" (exit 7).
set -eu

ADMIN_API_CONTAINER="${BOTWORK_ADMIN_API_CONTAINER:-botwork-admin-api}"
ADMIN_API_NETWORK="${BOTWORK_ADMIN_API_NETWORK:-botwork-internal}"
ADMIN_API_PORT="${BOTWORK_ADMIN_API_PORT:-9400}"
CONFIG_PATH="${BOTWORK_BOOTSTRAP_CONFIG:-/etc/botwork/bootstrap.yaml}"
OPERATOR="${BOTWORK_IMPORT_OPERATOR:-bootstrap-import}"
HEALTH_RETRIES="${BOTWORK_IMPORT_HEALTH_RETRIES:-60}"
HEALTH_TIMEOUT_SEC="${BOTWORK_IMPORT_HEALTH_TIMEOUT:-2}"

# Resolve admin-api's bridge IP on botwork-internal. The bridge
# driver makes container IPs reachable from the host netns; the
# DNS alias is not. Same pattern botwork-egress-iptables uses to
# discover the egress envoy.
ip="$(docker inspect "${ADMIN_API_CONTAINER}" \
  --format "{{(index .NetworkSettings.Networks \"${ADMIN_API_NETWORK}\").IPAddress}}" \
  2>/dev/null || true)"
if [ -z "${ip}" ]; then
  echo "botwork-import: ${ADMIN_API_CONTAINER} has no ${ADMIN_API_NETWORK} IP yet" >&2
  exit 7
fi

# Poll /admin/api/v1/health. `After=botwork-admin-api.service` only
# gates on `docker run` returning, not on the in-container axum
# bind. ~60s budget on the retry side, well under the unit's
# TimeoutStartSec=300.
i=0
while [ "${i}" -lt "${HEALTH_RETRIES}" ]; do
  if curl --silent --fail --max-time "${HEALTH_TIMEOUT_SEC}" \
       "http://${ip}:${ADMIN_API_PORT}/admin/api/v1/health" >/dev/null 2>&1; then
    break
  fi
  i=$((i + 1))
  sleep 1
done
if [ "${i}" -ge "${HEALTH_RETRIES}" ]; then
  echo "botwork-import: admin-api /health did not respond after ${HEALTH_RETRIES}s" >&2
  exit 8
fi

echo "botwork-import: admin-api ready at ${ip}:${ADMIN_API_PORT}, running bootstrap"
exec /usr/local/bin/botwork-tools bootstrap \
  --config "${CONFIG_PATH}" \
  --endpoint "http://${ip}:${ADMIN_API_PORT}" \
  --operator "${OPERATOR}"
