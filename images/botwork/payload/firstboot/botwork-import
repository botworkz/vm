#!/bin/sh
# botwork-import — boot-time DB seed via api (RFE #106 PR4).
#
# Called by botwork-import.service after api is up.
#
# Resolves api's bridge IP through `docker inspect` (the
# `admin_api` DNS alias is only resolvable inside botwork-internal,
# not from the host netns), polls /api/health until it
# answers, then runs `botwork-tools bootstrap` against the same IP.
#
# Why a script-on-disk vs. an inline `ExecStart=/usr/bin/sh -c '…'`:
# systemd parses `${foo}` in unit-file Exec* lines as its OWN
# environment-variable substitution BEFORE handing the string to
# the shell — so `${ip}` and `${i}` would never reach `sh` for
# assignment. Putting the script on disk dodges that entire
# substitution layer; systemd just execs the file.
#
# Why both inspect AND curl are inside the retry loop:
# systemd's `After=botwork-api.service` gates on the unit
# being "active" — which for a long-running container service
# means the `docker run` fork returned successfully, NOT that
# the container has joined botwork-internal and acquired an IP.
# In CI we see api's "Started" log line and import's exit-7
# log line at the same second; the inspect was racing the network
# attachment by a few hundred ms. Folding the inspect into the
# retry loop fixes the race.
#
# Exit codes match `botwork-tools bootstrap`'s 1:1 (see botwork's
# tools/src/bootstrap/mod.rs); we add exit 8 for "api never
# became reachable" which is distinct from "api answered but
# rejected the apply" (exit 6) and "api transport / 5xx
# mid-apply" (exit 7).
set -eu

API_CONTAINER="${BOTWORK_API_CONTAINER:-botwork-api}"
API_NETWORK="${BOTWORK_API_NETWORK:-botwork-internal}"
API_PORT="${BOTWORK_API_PORT:-9400}"
CONFIG_PATH="${BOTWORK_BOOTSTRAP_CONFIG:-/etc/botwork/bootstrap.yaml}"
OPERATOR="${BOTWORK_IMPORT_OPERATOR:-bootstrap-import}"
READY_RETRIES="${BOTWORK_IMPORT_READY_RETRIES:-60}"
CURL_TIMEOUT_SEC="${BOTWORK_IMPORT_CURL_TIMEOUT:-2}"

# Single retry loop covering BOTH "does the container have a bridge
# IP yet?" AND "does that IP answer /health?". Either failure mode
# is transient at boot (container starting up; axum binding); we
# don't care which one is the current blocker, only that we keep
# polling until both clear or we run out of time.
ip=""
i=0
while [ "${i}" -lt "${READY_RETRIES}" ]; do
  ip="$(docker inspect "${API_CONTAINER}" \
    --format "{{(index .NetworkSettings.Networks \"${API_NETWORK}\").IPAddress}}" \
    2>/dev/null || true)"
  if [ -n "${ip}" ] && [ "${ip}" != "<no value>" ]; then
    if curl --silent --fail --max-time "${CURL_TIMEOUT_SEC}" \
         "http://${ip}:${API_PORT}/api/health" >/dev/null 2>&1; then
      break
    fi
  fi
  i=$((i + 1))
  sleep 1
done

if [ "${i}" -ge "${READY_RETRIES}" ]; then
  echo "botwork-import: ${API_CONTAINER} on ${API_NETWORK} did not become reachable after ${READY_RETRIES}s (ip='${ip}')" >&2
  exit 8
fi

echo "botwork-import: api ready at ${ip}:${API_PORT}, running bootstrap"
exec /usr/local/bin/botwork-tools bootstrap \
  --config "${CONFIG_PATH}" \
  --endpoint "http://${ip}:${API_PORT}" \
  --operator "${OPERATOR}"
