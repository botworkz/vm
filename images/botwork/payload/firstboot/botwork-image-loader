#!/usr/bin/env bash
# botwork-image-loader — boot-time oneshot that loads the docker image
# tarballs we couldn't load at build time (virt-customize runs in an offline
# libguestfs appliance, so there's no docker daemon to load against).
#
# Idempotent: every loaded image gets retagged to botwork/<svc>:local, so on
# subsequent runs `docker image inspect botwork/<svc>:local` short-circuits
# the load (~50ms per call). The systemd unit
# (botwork-image-loader.service) is ordered Before=botwork-network.service
# and Required by it, so every downstream unit that references
# botwork/<svc>:local sees the tag.
#
# NOTE: this used to be guarded with a first-boot marker file under
# /var/lib/botwork, but in deploy topologies where /var/lib/botwork
# lives on a persistent data disk and the boot disk is recreated
# every redeploy (e.g. botspace), the marker survived while the
# docker image store did not — so the loader was skipped, every
# botwork/<svc>:local pull failed, and dependent units (config-broker,
# session-broker, …) cascaded into failure. We re-run unconditionally
# and let `docker image inspect` do the short-circuit.
set -euo pipefail

IMAGES_DIR="${BOTWORK_IMAGES_DIR:-/usr/share/botwork/images}"
# RFE #106 PR4 (botwork#118 + this PR): bootstrap retires; the
# host-side `botwork-import.service` calls `botwork-tools bootstrap`
# against admin-api instead of running a bootstrap container.
SERVICES=( session-broker config-broker control-plane db-migrate admin-api admin-ui postgres mcp-echo )

# Wait for the docker daemon to be reachable. systemd's
# After=docker.service only gates on the unit being *active* (the
# `dockerd` fork+exec succeeded), not on the API socket being ready.
# In practice it's almost always there by the time we run, but a tight
# loop with a 30s cap costs us nothing and pays back on slow first boots.
for _ in $(seq 1 60); do
  if docker info >/dev/null 2>&1; then
    break
  fi
  sleep 0.5
done

for svc in "${SERVICES[@]}"; do
  target="botwork/${svc}:local"

  if docker image inspect "${target}" >/dev/null 2>&1; then
    echo "${target} already present, skipping"
    continue
  fi

  tar="${IMAGES_DIR}/${svc}.tar"
  if [ ! -f "${tar}" ]; then
    echo "missing image tar: ${tar}" >&2
    exit 1
  fi

  # `docker load` output shape depends on what's inside the tarball:
  #
  #   "Loaded image: <name>:<tag>"        — legacy docker-save format
  #                                         (tarballs with a `repositories`
  #                                         file or v1 RepoTags manifest).
  #   "Loaded image ID: sha256:<hex>"     — OCI tarballs that don't carry
  #                                         a repo:tag mapping. Common for
  #                                         tarballs produced by
  #                                         `botforge deps` against an
  #                                         `oci://` source (shasset's
  #                                         OCI fetch path doesn't fake a
  #                                         `repositories` file).
  #
  # We don't care which: retag whatever was loaded to the deterministic
  # botwork/<svc>:local. Drop `-q` so the line is actually printed (`-q`
  # suppresses all output on success); a single docker load is fast
  # enough that the verbosity doesn't matter.
  load_out="$(docker load -i "${tar}")"
  loaded_ref="$(printf '%s\n' "${load_out}" \
    | sed -nE 's/^Loaded image( ID)?: //p' \
    | head -1)"
  if [ -z "${loaded_ref}" ]; then
    echo "could not parse loaded image ref for ${svc} from ${tar}" >&2
    echo "docker load output was:" >&2
    printf '%s\n' "${load_out}" >&2
    exit 1
  fi
  echo "loaded ${loaded_ref} from ${tar}; retagging to ${target}"
  docker tag "${loaded_ref}" "${target}"
done

echo "botwork-image-loader: all images present"
