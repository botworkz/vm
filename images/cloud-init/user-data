#cloud-config
# Deploy-time cloud-init seed template rendered by scripts/lib/build-seed.sh.
# Not used during Packer image build.
users:
- default
- name: debian
  shell: /bin/bash
  sudo: ALL=(ALL) NOPASSWD:ALL
  lock_passwd: true
  ssh_authorized_keys:
    - REPLACE_WITH_SSH_PUBLIC_KEY
- name: bot
  gecos: Bot Runtime User
  shell: /bin/bash
  sudo: ALL=(ALL) NOPASSWD:ALL
  lock_passwd: true
  ssh_authorized_keys:
  - REPLACE_WITH_SSH_PUBLIC_KEY

# All package management is done by the Packer shell provisioner so we
# never race against cloud-init for the dpkg lock, and so unattended
# upgrades never run during the build.
package_update: false
package_upgrade: false

ssh_pwauth: false
disable_root: true

write_files:
- path: /etc/ssh/sshd_config.d/60-botwork.conf
  permissions: "0644"
  owner: root:root
  content: |
    PasswordAuthentication no
    KbdInteractiveAuthentication no
    ChallengeResponseAuthentication no

runcmd:
- systemctl restart ssh || systemctl restart sshd || true
- mkdir -p /mnt/botwork-payload
- mount -o ro LABEL=botwork-payload /mnt/botwork-payload || echo "botwork payload not mounted; continuing with base image only"
- if [ -x /mnt/botwork-payload/bootstrap.sh ]; then bash /mnt/botwork-payload/bootstrap.sh; fi
