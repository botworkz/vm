
mkdir -p .shasset-cache

botforge() {
    export BOTFORGE_IMAGE="$(cat deps/botforge.Dockerfile | cut -d' ' -f2)"
    export HOST_UID="${HOST_UID:-$(id -u)}"
    export HOST_GID="${HOST_GID:-$(id -g)}"
    export HOST_KVM_GID="${HOST_KVM_GID:-$(getent group kvm | cut -d: -f3)}"

    local args=("$@")
    case "$1" in
        build|test)
            args+=(--cpus auto --color)
            ;;
    esac

    time docker compose run --remove-orphans botforge "${args[@]}"
}
