#!/usr/bin/env bash
# botwork-db-init — first-boot oneshot that materialises the postgres
# password + the BOTWORK_DATABASE_URL into /var/lib/botwork-db/secret.env.
#
# Lifetime: paired with the DB data disk. The secret lives next to the
# data it protects, so a fresh DB disk implies a fresh credential, and
# the credential survives every overlay/root-disk redeploy that keeps
# the data disk attached. There is no separate rotation flow in v0:
# operators rotate by deleting secret.env (and the data on the same
# disk) and rebooting — the next boot regenerates both.
#
# Contents (Env-file format, consumed by EnvironmentFile= on the postgres
# unit + the db-migrate / future broker units):
#
#   POSTGRES_USER=botwork
#   POSTGRES_DB=botwork
#   POSTGRES_PASSWORD=<32 random bytes hex-encoded>
#   BOTWORK_DATABASE_URL=postgres://botwork:<password>@postgres/botwork
#
# Why both the bare POSTGRES_* trio AND BOTWORK_DATABASE_URL in one file:
# the postgres image's entrypoint reads the trio at first run to initdb,
# and every rust consumer reads the composed URL at startup. One env-file
# avoids the "rotation skewed two files" failure mode.
#
# Idempotent: if secret.env already exists, this script exits 0 without
# touching it. That makes the unit safe to re-run on every boot, which
# matches the existing patterns (botwork-image-loader, botwork-network).
#
# NOTE on identity: this script runs as root (oneshot, before drop). The
# secret.env file is mode 0600 owned root:root because every consumer
# reads it via systemd's EnvironmentFile= which is parsed by systemd
# itself before the unit's User= drops privileges. Containers that need
# the values (postgres, db-migrate) get them through the env-file, not
# through filesystem reads of their own.
set -euo pipefail

SECRET_DIR="${BOTWORK_DB_SECRET_DIR:-/var/lib/botwork-db}"
SECRET_FILE="${SECRET_DIR}/secret.env"

# `install -d` to be safe if for whatever reason the DB disk's mount
# entry hasn't landed yet (the unit ordering should prevent that, but
# the cost of the safety net is one syscall).
install -d -m 0750 "${SECRET_DIR}"

if [ -s "${SECRET_FILE}" ]; then
  echo "botwork-db-init: ${SECRET_FILE} already present, leaving unchanged"
  exit 0
fi

# 32 bytes of random material, hex-encoded → 64 ASCII chars. No URL-unsafe
# characters so we can drop it straight into the BOTWORK_DATABASE_URL
# below without percent-encoding.
#
# openssl is pulled in by docker-ce-cli's dependency chain (via libssl3),
# but request it explicitly through `command -v` so a future repackaging
# can't silently drop it.
if ! command -v openssl >/dev/null 2>&1; then
  echo "botwork-db-init: openssl not found on PATH, cannot generate secret" >&2
  exit 1
fi
password="$(openssl rand -hex 32)"

# Write atomically: create at .tmp, fsync the directory via mv, then
# tighten perms. Anything reading the file before the mv sees no file
# at all (the [ -s ] guard above is also satisfied by this).
umask 077
tmp="${SECRET_FILE}.tmp"
cat > "${tmp}" <<EOF
# Generated by botwork-db-init.service on $(date -u +%Y-%m-%dT%H:%M:%SZ).
# Lifetime is paired with the DB data disk under ${SECRET_DIR}.
# To rotate: stop botwork-postgres.service, delete this file AND the
# data/ directory on the same disk, restart — credential and data are
# regenerated together.
POSTGRES_USER=botwork
POSTGRES_DB=botwork
POSTGRES_PASSWORD=${password}
BOTWORK_DATABASE_URL=postgres://botwork:${password}@postgres/botwork
EOF
chmod 0600 "${tmp}"
chown root:root "${tmp}"
mv "${tmp}" "${SECRET_FILE}"

echo "botwork-db-init: wrote ${SECRET_FILE} (mode 0600, root:root)"
